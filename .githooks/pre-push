#!/bin/sh
# Local-first pre-push — ADVISORY (never blocks the push, exits 0 regardless). Auto-enabled
# via package.json's "prepare" script (git config core.hooksPath .githooks).
#
# This repo is PUBLIC, so its GH Actions minutes are already free/unlimited — ci.yml's own
# typecheck-build + e2e-vs-preview jobs are UNCHANGED and stay the real gate. This hook is
# purely additive: faster local feedback (mirrors ci.yml's typecheck-build steps) before
# waiting on a PR/preview round-trip, added as part of the 2026-07-16 GitHub Actions minutes
# offload work (root repo miyagi-product-management) — same local-first pattern, applied here
# for consistency/faster feedback even though there's no billing reason to.

if ! command -v node >/dev/null 2>&1; then
  exit 0
fi

echo "pre-push: type-checking..." >&2
if ! npx tsc --noEmit; then
  echo "pre-push: tsc --noEmit failed — advisory only, push proceeding. ci.yml will also catch this." >&2
fi

echo "pre-push: building..." >&2
if ! npm run build; then
  echo "pre-push: build failed — advisory only, push proceeding. ci.yml will also catch this." >&2
fi

exit 0
