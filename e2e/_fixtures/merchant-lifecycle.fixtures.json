      }
    },
    {
      "name": "no data key at all",
      "expect": { "kind": "invalid", "reason": "missing_merchant_subject" },
      "envelope": {
        "id": "7d8e9f0a-1b2c-43d4-e5f6-a7b8c9d0e1f2",
